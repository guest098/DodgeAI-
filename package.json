{
  "name": "sap-order-to-cash-graph",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "ingest": "npm run ingest -w apps/api",
    "build": "npm run build -w apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
